<launch>
  <arg name="serial_no_camera_a" default="" />
  <arg name="serial_no_camera_b" default="" />
  <arg name="camera_name_a" default="camera_a" />
  <arg name="camera_name_b" default="camera_b" />
  <arg name="color_width" default="1920" />
  <arg name="color_height" default="1080" />
  <arg name="color_fps" default="30" />

  <arg name="enable_depth" default="false" />
  <arg name="enable_infra1" default="false" />
  <arg name="enable_infra2" default="false" />
  <arg name="enable_gyro" default="false" />
  <arg name="enable_accel" default="false" />
  <arg name="enable_pointcloud" default="false" />

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="$(arg camera_name_a)" />
    <arg name="serial_no" value="$(arg serial_no_camera_a)" />
    <arg name="enable_color" value="true" />
    <arg name="enable_depth" value="$(arg enable_depth)" />
    <arg name="enable_infra1" value="$(arg enable_infra1)" />
    <arg name="enable_infra2" value="$(arg enable_infra2)" />
    <arg name="enable_gyro" value="$(arg enable_gyro)" />
    <arg name="enable_accel" value="$(arg enable_accel)" />
    <arg name="pointcloud" value="$(arg enable_pointcloud)" />
    <arg name="color_width" value="$(arg color_width)" />
    <arg name="color_height" value="$(arg color_height)" />
    <arg name="color_fps" value="$(arg color_fps)" />
  </include>

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="camera" value="$(arg camera_name_b)" />
    <arg name="serial_no" value="$(arg serial_no_camera_b)" />
    <arg name="enable_color" value="true" />
    <arg name="enable_depth" value="$(arg enable_depth)" />
    <arg name="enable_infra1" value="$(arg enable_infra1)" />
    <arg name="enable_infra2" value="$(arg enable_infra2)" />
    <arg name="enable_gyro" value="$(arg enable_gyro)" />
    <arg name="enable_accel" value="$(arg enable_accel)" />
    <arg name="pointcloud" value="$(arg enable_pointcloud)" />
    <arg name="color_width" value="$(arg color_width)" />
    <arg name="color_height" value="$(arg color_height)" />
    <arg name="color_fps" value="$(arg color_fps)" />
  </include>
</launch>
